# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Database (matches docker-compose service)
DATABASE_URL=postgresql://copilot:copilot@localhost:5432/restaurant_ops

# MCP mode: "synthetic" uses our local server; "real" points at https://mcp.swiggy.com/im
MCP_MODE=synthetic

# Only needed when MCP_MODE=real
SWIGGY_MCP_URL=https://mcp.swiggy.com/im
SWIGGY_API_KEY=

# Forecasting
FORECAST_HORIZON_DAYS=7
